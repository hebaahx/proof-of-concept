<!DOCTYPE html>
<html lang="en">
        
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Pokédex</title>
        <link rel="stylesheet" href="/style.css" />
    </head>


    <body>

        <header>
            <img src="/assets/pokemon-logo.png" alt="Pokémon logo" class="logo">
        </header>    

        <!-- Sidebar en navigatie -->
        <nav>
           <form action="/" method="GET"> 
                <label for="search" class="sr-only">Search Pokémon</label>
                <input type="search" id="search" name="search" placeholder="Find a Pokémon by name or type...">
                <button type="submit">Search</button>
            </form>    
           
            <ul class="nav__list">
                <li>
                    <a href="/"
                        class="nav__link {% unless isCaughtPage %}nav__link--active{% endunless %}">
                        All Pokémon
                    </a>
                </li>
                <li>
                    <a href="/?caught=true"
                        class="nav__link {% if isCaughtPage %}nav__link--active{% endif %}">
                        Caught Pokémon
                    </a>
                </li>
            </ul>

        </nav>


        <main id="main-content">
            
            <h1>All Pokémon</h1>

            {% if error %}
                <p class="error">{{ error }}</p>
            {% endif %}

            <ul class="pokemon-list">
                {% for pokemon in pokemonList %}
                <li class="pokemon-list__item">
                    <a href="/pokemon/{{ pokemon.id }}" class="card type-{{ pokemon.types[0] }}">
                        {% if pokemon.isCaught %}
                            <img src="/assets/pokeball.svg" alt="Caught" class="card__pokeball" />
                        {% endif %}
                    <span class="card__name">{{ pokemon.name | capitalize }}</span>
                    <img
                        src="{{ pokemon.image }}"
                        alt="{{ pokemon.name | capitalize }}"
                        class="card__image"
                        loading="lazy"
                    />
                    </a>
                </li>
                {% endfor %}
            </ul>
        </main>

    </body>
</html>